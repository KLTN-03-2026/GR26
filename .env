# =============================================================================
# SmartF&B Docker Compose Environment — Development
# File này được Docker Compose tự load khi chạy từ root GR26.
# KHÔNG commit file này nếu dùng secret thật.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=smartfnb
POSTGRES_USER=smartfnb
POSTGRES_PASSWORD=smartfnb123
POSTGRES_HOST_PORT=5433

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST_PORT=6379

# -----------------------------------------------------------------------------
# Backend Spring Boot
# -----------------------------------------------------------------------------
BACKEND_HOST_PORT=8080
SPRING_PROFILES_ACTIVE=docker
BASE_URL=http://localhost:8080

# Backend gọi AI Service qua Docker DNS name trong smartfnb-network.
AI_SERVICE_URL=http://ai-service:8001
AI_CONNECT_TIMEOUT_MS=5000
AI_READ_TIMEOUT_MS=10000

# JWT secret dev phải khớp giữa Backend và AI Service.
JWT_SECRET='SmartFnbSuperSecretKeyForDockerDeploy2026ChangeMe!@#$%'
JWT_ALGORITHM=HS384
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_MS=604800000

# PayOS encryption key dev Base64 decode ra 32 bytes cho AES-256.
PAYOS_ENCRYPTION_KEY=c21hcnRmbmItZGV2LXBheW9zLWtleS0yMDI2ISEhISE=

# -----------------------------------------------------------------------------
# AI Service FastAPI
# -----------------------------------------------------------------------------
AI_ENV=development
AI_SERVICE_HOST_PORT=8001
AI_LOG_LEVEL=INFO

# Folder trong container, không phải path host.
MODEL_STORAGE_DIR=/app/storage/models
LOG_DIR=/app/logs

# NeuralProphet config
NP_N_LAGS=28
NP_N_FORECASTS=7
NP_EPOCHS=150
NP_BATCH_SIZE=32
NP_MIN_DAYS_REQUIRED=30

# Scheduler cron theo Asia/Ho_Chi_Minh
TRAIN_CRON_HOUR=2
TRAIN_CRON_DAY_OF_WEEK=sun
PREDICT_CRON_HOUR=0
PREDICT_CRON_MINUTE=30
WEATHER_CRON_HOUR=6
WEATHER_CACHE_DAYS=1

# CORS — JSON array, giữ nguyên dấu quote.
ALLOWED_ORIGINS='["http://localhost:5173","http://localhost:3000","http://localhost:8080"]'

# Optional alerts
ALERT_WEBHOOK_URL=
