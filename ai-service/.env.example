# =============================================================================
# SmartF&B AI Service — Environment Variables
# Copy file này thành .env và điền giá trị thực
# =============================================================================

# --- Database (dùng chung schema với BE Spring Boot) ---
DATABASE_URL=postgresql+asyncpg://smartfnb:password@localhost:5432/smartfnb_db

# --- AI Service ---
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
# debug | info | warning | error
LOG_LEVEL=INFO

# --- Security (dùng chung secret với Spring Boot) ---
# Phải khớp với jwt.secret trong application.yml của BE
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# --- Model Storage ---
# Thư mục lưu file .np của trained models
MODEL_STORAGE_DIR=./storage/models

# --- Scheduler ---
# Train Global Model: Chủ nhật 2:00 AM
TRAIN_CRON_HOUR=2
TRAIN_CRON_DAY_OF_WEEK=sun

# Predict all branches: hàng ngày 00:30 AM
PREDICT_CRON_HOUR=0
PREDICT_CRON_MINUTE=30

# Fetch weather: hàng ngày 6:00 AM
WEATHER_CRON_HOUR=6

# --- Weather API (Open-Meteo — miễn phí, không cần key) ---
# Số ngày cache thời tiết trong DB trước khi fetch lại
WEATHER_CACHE_DAYS=1

# --- NeuralProphet ---
# Số ngày nhìn lại để học pattern
NP_N_LAGS=14
# Số ngày dự báo tới
NP_N_FORECASTS=7
# Số epoch train
NP_EPOCHS=100

# API KEY Ollama 
API_KEY_OLLAMA=29773fccaa57406da63c8bba04dc6d18.ICC5U_9_YCwxizDkGX6v6wBs 