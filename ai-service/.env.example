# =============================================================================
# SmartF&B AI Service — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git
# =============================================================================

# --- Môi trường ---
# development | production | test
ENV=development

# --- Database (dùng chung PostgreSQL với BE Spring Boot) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/smartfnb_db

# --- AI Service ---
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
# debug | info | warning | error
LOG_LEVEL=INFO

# --- Security (PHẢI khớp với Spring Boot application.yml) ---
# Thay bằng secret thực — không để "changeme" trong production
JWT_SECRET=SmartFnbSuperSecretKeyForDockerDeploy2026ChangeMe!@#$%
JWT_ALGORITHM=HS384

# --- Model Storage ---
# Thư mục lưu file .np của trained models
MODEL_STORAGE_DIR=./storage/models

# --- Logging ---
# Folder gốc chứa log — bên trong tổ chức theo ngày: logs/YYYY-MM-DD/
LOG_DIR=./logs

# --- NeuralProphet ---
# Số ngày nhìn lại để học pattern (tham chiếu; thực tế _auto_n_lags() tính theo active_days)
NP_N_LAGS=28
# Số ngày dự báo tới
NP_N_FORECASTS=7
# Số epoch train
NP_EPOCHS=150
# Batch size
NP_BATCH_SIZE=32
# Số ngày tối thiểu để train
NP_MIN_DAYS_REQUIRED=30

# --- Scheduler cron (Asia/Ho_Chi_Minh) ---
# Train Global Model: Chủ nhật 2:00 AM
TRAIN_CRON_HOUR=2
TRAIN_CRON_DAY_OF_WEEK=sun

# Predict all branches: hàng ngày 00:30 AM
PREDICT_CRON_HOUR=0
PREDICT_CRON_MINUTE=30

# Fetch weather: hàng ngày 6:00 AM
WEATHER_CRON_HOUR=6

# --- Weather API (Open-Meteo — miễn phí, không cần key) ---
# Số ngày cache thời tiết trong DB trước khi fetch lại
WEATHER_CACHE_DAYS=1

# --- Optional alerts (để trống nếu không dùng) ---
ALERT_WEBHOOK_URL=
